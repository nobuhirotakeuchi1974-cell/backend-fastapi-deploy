# アプリ設定（.envで上書き可）
APP_NAME="Human Capital OS"
APP_VERSION="0.1.0"
DEBUG=True

# SQLite（ローカル開発用）
DATABASE_URL="sqlite+aiosqlite:///./human_capital.db"

# JWT（本番環境では必ず変更すること）
SECRET_KEY="change-me-in-production-use-a-long-random-string"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS（カンマ区切りで複数指定可）
CORS_ORIGINS="http://localhost:3000"
